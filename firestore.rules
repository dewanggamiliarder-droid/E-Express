rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId &&
               data.email is string &&
               data.balance is number &&
               data.accountId is string &&
               (!('name' in data) || data.name is string) &&
               (!('displayName' in data) || data.displayName is string) &&
               (!('photoURL' in data) || data.photoURL is string || data.photoURL == null) &&
               (!('avatar' in data) || data.avatar is string || data.avatar == null) &&
               (!('phone' in data) || data.phone is string) &&
               (data.createdAt != null) &&
               (!('lastLogin' in data) || data.lastLogin != null);
      }

      // Owner can read and write their own profile
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());

      // Transfers: Senders can update recipient balance
      allow update: if isSignedIn() && 
                    isValidId(userId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['balance']) &&
                    incoming().balance > existing().balance;

      // For account lookup
      allow get, list: if isSignedIn(); 

      // --- Transaction Sub-collection ---
      match /transactions/{transactionId} {
        function isValidTransaction(data) {
          return data.amount is number &&
                 data.type is string &&
                 data.status in ['BERHASIL', 'PENDING', 'GAGAL'] &&
                 data.createdAt != null;
        }

        // Only owner can read history
        allow read: if isOwner(userId);
        
        // Owner can create records
        allow create: if isOwner(userId) && isValidTransaction(incoming());
        
        // Senders can create "income" records for recipients
        allow create: if isSignedIn() && 
                      incoming().recipientUid == userId && 
                      incoming().isPositive == true &&
                      incoming().senderUid == request.auth.uid &&
                      isValidTransaction(incoming());
      }
    }

    match /test/connection {
      allow get: if true;
    }
  }
}
